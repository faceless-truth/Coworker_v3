# MC & S CoWorker v3 — Environment Variables
# Copy this to .env and fill in real values. Never commit .env to git.

# Environment
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://coworker:CHANGE_ME@localhost:5432/coworker?ssl=disable
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Microsoft (development fallback only)
MS_CLIENT_ID_FALLBACK=
MS_CLIENT_SECRET_FALLBACK=
MS_TENANT_ID_FALLBACK=

# Encryption — generate with: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
MASTER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64

# Shadow mode — set to False only when ready to write to external systems
SHADOW_MODE=True

# Webhook validation — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
GRAPH_WEBHOOK_CLIENT_STATE=CHANGE_ME

# DigitalOcean Spaces (for backups)
SPACES_REGION=syd1
SPACES_BUCKET=coworker-v3-backups-syd1
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
